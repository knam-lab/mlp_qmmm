# ------------------------------------------------
# INTERMEDIATE — MLP (E_high demeaned)
# ------------------------------------------------
adapter: charmmmndo97mts
input: ./data_adk

adapter_kwargs:
  # --- faster parsing ---
  workers: 8                    # number of parser processes based CPU cores availability
  mp_chunk: 2                   # files per worker "wave" (load balancing)
  verbose: true                 # print parsing progress

  energy_mode: diff_demean
  compute_deltas: true
  max_mm: 3000                  # pad/truncate MM to this many sites (tensor width)
  # --- outlier filtering ---
  energy_outlier: true
  energy_outlier_fence_k: 1.5   # Tukey fence constant
  grad_outlier: true
  grad_outlier_fence_k: 1.5
  grad_outlier_metric: median_l2  # mean_l2 | max_l2 | median_l2 (vector norm over atoms)
  grad_outlier_keys: ["qm_dgrad", "mm_dgrad", "qm_grad_high","qm_grad_low","mm_grad_high","mm_grad_low"]  # keys used only to score outliers
  write_summary: true
  summary_json_path: runs/trial1_equ/parse_summary.json
  summary_txt_path:  runs/trial1_equ/parse_summary.txt

